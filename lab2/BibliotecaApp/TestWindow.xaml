<Window x:Class="BibliotecaApp.TestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Transactions and Concurrency" Height="650" Width="850">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,15,0">
            <TextBlock Text="1/2. Concurrency and Deadlock" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
            <Button x:Name="btnDirtyRead" Content="A. Dirty Read" Margin="0,0,0,5" Padding="5" Click="btnDirtyRead_Click"/>
            <Button x:Name="btnNonRepeatable" Content="B. Non-Repeatable Read" Margin="0,0,0,5" Padding="5" Click="btnNonRepeatable_Click"/>
            <Button x:Name="btnPhantom" Content="C. Phantom Read" Margin="0,0,0,5" Padding="5" Click="btnPhantom_Click"/>
            <Button x:Name="btnLostUpdate" Content="D. Lost Update" Margin="0,0,0,5" Padding="5" Click="btnLostUpdate_Click"/>
            <Button x:Name="btnDeadlock" Content="E1. Deadlock (Error)" Margin="0,0,0,5" Padding="5" Click="btnDeadlock_Click"/>
            <Button x:Name="btnDeadlockResolved" Content="E2. Deadlock (Resolved)" Margin="0,0,0,10" Padding="5" Click="btnDeadlockResolved_Click"/>

            <Separator Margin="0,5,0,10"/>

            <TextBlock Text="3. Performance (5000 Inserts)" FontWeight="Bold" Margin="0,0,0,10" HorizontalAlignment="Center"/>
            <Button x:Name="btnPerfAuto" Content="Test: Auto-Commit" Margin="0,0,0,5" Padding="5" Click="btnPerfAuto_Click"/>
            <Button x:Name="btnPerfBatch100" Content="Test: Commit la 100" Margin="0,0,0,5" Padding="5" Click="btnPerfBatch100_Click"/>
            <Button x:Name="btnPerfSingle" Content="Test: Single TX (NpgsqlBatch)" Margin="0,0,0,5" Padding="5" Click="btnPerfSingle_Click"/>

            <Button x:Name="btnRunFullBenchmark" Content="RUN FULL BENCHMARK (3x)" Margin="0,10,0,10" Padding="10" Background="LightGreen" FontWeight="Bold" Click="btnRunFullBenchmark_Click"/>

            <Separator Margin="0,5,0,10"/>
            <Button Content="Clear Log" Margin="0,0,0,0" Padding="10" Click="btnClearLog_Click" Background="#FFDDDD"/>
        </StackPanel>

        <TextBox x:Name="txtLog" Grid.Column="1" IsReadOnly="True" 
                 TextWrapping="Wrap" AcceptsReturn="True" 
                 VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="13" Padding="5"/>
    </Grid>
</Window>