<Window x:Class="BibliotecaApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Library" Height="600" Width="900">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="Refresh Data" Width="100" Click="btnRefresh_Click" Padding="5" Margin="0,0,20,0"/>
            <Button Content="Run Tests" Width="100" Click="btnOpenTests_Click" Padding="5" Margin="0,0,20,0" Background="LightBlue"/>
            <TextBlock Text="Search Author:" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox x:Name="txtSearch" Width="200" VerticalAlignment="Center" TextChanged="txtSearch_TextChanged" Padding="2"/>
        </StackPanel>

        <DataGrid x:Name="dgAuthors" Grid.Row="1" Grid.Column="0" AutoGenerateColumns="False" 
                  SelectionMode="Single" SelectionChanged="dgAuthors_SelectionChanged"
                  IsReadOnly="True" CanUserSortColumns="True" Margin="0,0,10,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}"/>
                <DataGridTextColumn Header="Nationality" Binding="{Binding Nationality}"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid x:Name="dgBooks" Grid.Row="0" AutoGenerateColumns="False" 
                      IsReadOnly="True" SelectionMode="Single" CanUserSortColumns="True"
                      SelectionChanged="dgBooks_SelectionChanged" Margin="0,0,0,10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}"/>
                    <DataGridTextColumn Header="Title" Binding="{Binding Title}"/>
                    <DataGridTextColumn Header="Year" Binding="{Binding PublicationYear}"/>
                    <DataGridTextColumn Header="Categories" Binding="{Binding CategoriesDisplay}"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Title:" Grid.Row="0" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtTitle" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10"/>

                    <TextBlock Text="Year:" Grid.Row="1" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtYear" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10"/>

                    <TextBlock Text="Categories:" Grid.Row="2" Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Top"/>
                    <ListBox x:Name="lstCategories" Grid.Row="2" Grid.Column="1" 
                             SelectionMode="Multiple" DisplayMemberPath="Name" Height="80"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Clear Form" Width="85" Margin="0,0,10,0" Click="btnClear_Click" Padding="5"/>
                <Button Content="Add Book" Width="85" Margin="0,0,10,0" Click="btnAdd_Click" Padding="5"/>
                <Button Content="Update Book" Width="85" Margin="0,0,10,0" Click="btnUpdate_Click" Padding="5"/>
                <Button Content="Delete Book" Width="85" Click="btnDelete_Click" Padding="5"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>